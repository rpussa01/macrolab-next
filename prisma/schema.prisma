generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  ingredients String
  method      String
  image       String?
  calories Int?
  protein  Int?
  carbs    Int?
  fat      Int?
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}